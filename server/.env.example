# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/franchisesim"

# JWT Secrets (use long random strings in production)
JWT_SECRET="change-this-customer-jwt-secret"
JWT_ADMIN_SECRET="change-this-admin-jwt-secret"

# Server
PORT=3001
NODE_ENV="development"
CLIENT_URL="http://localhost:5173"
COOKIE_DOMAIN="localhost"

# Email (nodemailer — fill in for password reset & verification emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@youromain.com"
SMTP_PASS="your-app-password"

# File storage
UPLOAD_DIR="./uploads"

# 공공 API 연동 (시세 자동 가져오기)
# - data.go.kr 에서 "조달청 종합쇼핑몰 상품정보" 서비스 활용신청 후 디코딩된 일반 인증키 사용
# - 키가 비어 있으면 DEMO 데이터로 동작 (배너로 표시됨)
G2B_API_KEY=""
G2B_SHOPPING_ENDPOINT="http://apis.data.go.kr/1230000/ShoppingMallPrdctInfoService/getMASCntrctPrdctInfoList"
PUBLIC_DATA_API_KEY=""
